# =============================================================================
# E-Nutrition Backend — Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# --- General ---
NODE_ENV=develop
PORT=3000

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-database-password
DB_NAME=e_nutrition_db
DB_TYPE=postgres
MAX_POOL_SIZE=10
MIN_POOL_SIZE=2
DB_SSL=false
DB_SYNCHRONIZE=true

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
SALT_ROUNDS=10

# --- AWS S3 (Canada — ca-central-1) ---
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION=ca-central-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SES_REGION=ca-central-1

# --- Default user (seed / admin) ---
DEFAULT_USER_NAME=Admin
DEFAULT_PASSWORD=TempPass123!

# --- Upload limits ---
IMAGE_FILE_SIZE=5MB
VIDEO_FILE_SIZE=100MB
AUDIO_FILE_SIZE=50MB
IMAGE_FIELD_SIZE=10MB

# --- Email (SendGrid) ---
SEND_GRID_API_KEY=your-sendgrid-api-key
SUPPORT_SENDER_EMAIL=noreply@yourdomain.com
SECURITY_EMAIL=security@yourdomain.com

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:3600/user/google/redirect
GOOGLE_CANCEL_REDIRECT_URL=http://localhost:3000

# --- Frontend redirect pages ---
USER_EMAIL_VERIFICATION_PAGE=https://your-frontend.com/verify-email
USER_RESET_PASSWORD_PAGE=https://your-frontend.com/reset-password
USER_SET_PASSWORD_PAGE=https://your-frontend.com/set-password
SOCIAL_MEDIA_REDIRECT_URL=http://localhost:3000

# --- Logout routes (optional) ---
ADMIN_LOGOUT_ROUTE=/admin/logout
USER_LOGOUT_ROUTE=/user/logout
